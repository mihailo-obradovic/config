# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
# font-family = "JetBrainsMono Nerd Font"
# font-style = Regular
font-size = 11

# Window
window-theme = ghostty
# window-padding-x = 14
# window-padding-y = 14
# confirm-close-surface=false
# resize-overlay = never
gtk-toolbar-style = flat
# TODO: Check if needed
window-decoration = none
focus-follows-mouse = true

# Cursor styling
cursor-style = "bar"
# cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Misc.
working-directory = /home/mihailo/Projects

# Keyboard bindings
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# Split/tab view controls
keybind = ctrl+shift+down=new_split:down
keybind = ctrl+shift+right=new_split:right

keybind = alt+up=goto_split:up
keybind = alt+down=goto_split:down
keybind = alt+right=goto_split:right
keybind = alt+left=goto_split:left

keybind = alt+z=toggle_tab_overview
keybind = alt+x=toggle_split_zoom
keybind = alt+c=close_surface

# Resizing controls; movements equal exactly one row/column
keybind = ctrl+alt+up=resize_split:up,21
keybind = ctrl+alt+down=resize_split:down,21
keybind = ctrl+alt+left=resize_split:left,11
keybind = ctrl+alt+right=resize_split:right,11
keybind = ctrl+alt+0=equalize_splits

# Unbind unused/unwanted default keybinds
keybind = ctrl+page_down=unbind
keybind = ctrl+page_up=unbind
keybind = ctrl+insert=unbind
keybind = super+ctrl+left_bracket=unbind
keybind = super+ctrl+right_bracket=unbind
keybind = super+ctrl+shift+up=unbind
keybind = super+ctrl+shift+down=unbind
keybind = super+ctrl+shift+right=unbind
keybind = super+ctrl+shift+left=unbind
keybind = ctrl+shift+up=unbind
keybind = ctrl+shift+left=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+o=unbind
keybind = super+ctrl+shift+equal=unbind
keybind = ctrl+equal=unbind
keybind = ctrl+shift+q=unbind
keybind = ctrl+shift+enter=unbind
keybind = ctrl+enter=unbind
keybind = alt+f4=unbind
keybind = shift+insert=unbind

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
